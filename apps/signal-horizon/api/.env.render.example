# Signal Horizon API - Render deployment template

NODE_ENV=production
HOST=0.0.0.0

# Render auto-injects this from the Blueprint's managed Postgres service.
# Keep it here as a reference for non-Blueprint or manual environments.
DATABASE_URL=postgresql://signal_horizon:password@host:5432/signal_horizon

# Render auto-injects this from the Blueprint's managed Redis service.
# Keep it here as a reference for non-Blueprint or manual environments.
REDIS_URL=redis://default:password@host:6379
ENABLE_JOB_QUEUE=true

# Security
JWT_SECRET=replace-with-long-random-secret
TELEMETRY_JWT_SECRET=replace-with-long-random-secret
CONFIG_ENCRYPTION_KEY=replace-with-long-random-secret
METRICS_AUTH_TOKEN=replace-with-long-random-secret

# Frontend origin
CORS_ORIGINS=https://app.signal-horizon.example.com

# Optional ClickHouse
CLICKHOUSE_ENABLED=false
CLICKHOUSE_HOST=clickhouse.example.com
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_DB=signal_horizon
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=replace-with-clickhouse-password
