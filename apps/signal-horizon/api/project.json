{
  "name": "signal-horizon-api",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/signal-horizon/api/src",
  "projectType": "application",
  "tags": ["scope:signal-horizon", "type:api"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch src/index.ts",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsup src/index.ts --format esm --dts",
        "cwd": "apps/signal-horizon/api"
      },
      "dependsOn": ["db:generate"],
      "outputs": ["{projectRoot}/dist"]
    },
    "build:standalone": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build",
        {
          "projects": ["signal-horizon-ui"],
          "target": "build"
        }
      ],
      "options": {
        "command": "node ../scripts/build-standalone.mjs",
        "cwd": "apps/signal-horizon/api"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/index.js",
        "cwd": "apps/signal-horizon/api"
      },
      "dependsOn": ["build"]
    },
    "db:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma generate",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate dev",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "db:migrate:prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate deploy",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "db:reset": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate reset --force --skip-seed",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "db:reseed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate reset --force --skip-seed && tsx prisma/seed.ts",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "db:reseed:medium": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate reset --force --skip-seed && tsx prisma/seed.ts --profile=medium",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "db:reseed:large": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma migrate reset --force --skip-seed && tsx prisma/seed.ts --profile=large",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "db:studio": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prisma studio",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "db:seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx prisma/seed.ts",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src --ext .ts",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest",
        "cwd": "apps/signal-horizon/api"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --coverage",
        "cwd": "apps/signal-horizon/api"
      }
    }
  }
}
