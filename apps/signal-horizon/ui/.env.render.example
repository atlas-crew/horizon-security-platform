# Signal Horizon UI - Render deployment template

# Public API origin used by the browser
VITE_API_URL=https://api.signal-horizon.example.com

# Dashboard gateway used by the browser
VITE_WS_URL=wss://api.signal-horizon.example.com/ws/dashboard

# Optional browser-side bearer auth for non-cookie setups.
# Leave unset for normal production browser use unless you explicitly want this mode.
# VITE_HORIZON_API_KEY=
